{% extends 'base_admin.html.twig' %}

{% block title %}Gestion des visiteurs
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2>
			<i class="fas fa-user me-2"></i>Visiteurs</h2>
		<a href="{{ path('admin_user_index') }}" class="btn btn-secondary">
			<i class="fas fa-arrow-left me-2"></i>Retour utilisateurs
		</a>
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<table id="table-visiteurs" class="table table-hover mb-0">
				<thead class="table-success">
					<tr>
						<th>Nom</th>
						<th>Prénom</th>
						<th>Téléphone</th>
						<th>Commentaires</th>
						<th class="text-end">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for pu in public_users %}
						<tr>
							<td>{{ pu.nom }}</td>
							<td>{{ pu.prenom }}</td>
							<td>{{ pu.phone }}</td>
							<td>{{ pu.comments|length }}</td>
							<td class="text-end">
								<a href="{{ path('admin_public_user_edit', {id: pu.id}) }}" class="btn btn-sm btn-warning">
									<i class="fas fa-edit"></i>
								</a>
								<button class="btn btn-sm btn-danger" onclick="confirmDelete({{ pu.id }}, '{{ pu.prenom }} {{ pu.nom }}')">
									<i class="fas fa-trash"></i>
								</button>
								<form id="delete-{{ pu.id }}" action="{{ path('admin_public_user_delete', {id: pu.id}) }}" method="post" class="d-none">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ pu.id) }}">
								</form>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="text-center text-muted py-4">Aucun visiteur.</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	<script>
		function confirmDelete(id, nom) {
Swal.fire({
title: 'Supprimer ce visiteur ?',
text: nom,
icon: 'warning',
showCancelButton: true,
confirmButtonColor: '#e74c3c',
cancelButtonColor: '#95a5a6',
confirmButtonText: 'Oui, supprimer',
cancelButtonText: 'Annuler'
}).then((result) => {
if (result.isConfirmed) {
document.getElementById('delete-' + id).submit();
}
});
}

$('#table-visiteurs').DataTable({
language: {
url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json'
},
columnDefs: [
{
orderable: false,
targets: -1
}
] // colonne Actions non triable
});
	</script>
{% endblock %}
