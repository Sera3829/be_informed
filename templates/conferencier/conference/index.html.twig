{% extends 'base_admin.html.twig' %}

{% block title %}Mes conférences
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2>
			<i class="fas fa-chalkboard-teacher me-2"></i>Mes conférences</h2>
		<button type="button" class="btn btn-primary" data-form-url="{{ path('conferencier_conference_new') }}">
			<i class="fas fa-plus me-2"></i>Nouvelle conférence
		</button>
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<table class="table table-hover mb-0">
				<thead class="table-primary">
					<tr>
						<th>Titre</th>
						<th>Lieu</th>
						<th>Date</th>
						<th class="text-end">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for conference in conferences %}
						<tr>
							<td>{{ conference.titre }}</td>
							<td>{{ conference.lieu }}</td>
							<td>{{ conference.date|date('d/m/Y H:i') }}</td>
							<td class="text-end">
								<button type="button" class="btn btn-sm btn-warning" data-form-url="{{ path('conferencier_conference_edit', {id: conference.id}) }}" title="Modifier">
									<i class="fas fa-edit"></i>
								</button>
								<button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete({{ conference.id }}, '{{ conference.titre|e('js') }}')" title="Supprimer">
									<i class="fas fa-trash"></i>
								</button>
								<form id="delete-form-{{ conference.id }}" action="{{ path('conferencier_conference_delete', {id: conference.id}) }}" method="post" class="d-none">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ conference.id) }}">
								</form>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4" class="text-center text-muted py-4">Vous n'avez pas encore de conférences.</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>

	{% include 'partials/_crud_modal.html.twig' %}
{% endblock %}

{% block javascripts %}
	<script>
		function confirmDelete(id, titre) {
			Swal.fire({
				title: 'Supprimer cette conférence ?',
				text: titre,
				icon: 'warning',
				showCancelButton: true,
				confirmButtonColor: '#e74c3c',
				cancelButtonColor: '#95a5a6',
				confirmButtonText: 'Oui, supprimer',
				cancelButtonText: 'Annuler'
			}).then((result) => {
				if (result.isConfirmed) {
					document.getElementById('delete-form-' + id).submit();
				}
			});
		}
	</script>
{% endblock %}
