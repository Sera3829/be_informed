{% extends 'base.html.twig' %}
{% import _self as ui %}

{% block title %}Conférences
{% endblock %}

{% block stylesheets %}
	<style>
		/* --- Hero --- */
		.hero-section {
			background: linear-gradient(135deg, #22313f 0%, #2c3e50 45%, #2f6da8 100%);
			color: white;
			padding: 3.5rem 0 4.5rem;
			margin: -1.5rem 0 -2.5rem;
		}
		.hero-section .lead {
			opacity: .8;
			font-size: 1.05rem;
		}
		.search-bar {
			max-width: 520px;
			margin: 1.75rem auto 0;
			position: relative;
		}
		.search-bar .fa-search {
			position: absolute;
			left: 1.25rem;
			top: 50%;
			transform: translateY(-50%);
			color: #8a97a8;
		}
		.search-bar input {
			padding-left: 3rem;
			border: none;
			box-shadow: 0 10px 30px rgba(0, 0, 0, .25);
		}

		.page-content {
			position: relative;
			z-index: 1;
			margin-top: 4rem;
		}

		/* --- Titres de section --- */
		.section-title {
			display: flex;
			align-items: center;
			gap: .6rem;
			font-size: 1.15rem;
			font-weight: 700;
			color: #29323d;
			margin-bottom: 1.25rem;
		}
		.section-title .count-pill {
			background: #eef3fb;
			color: #2f6da8;
			border-radius: 50rem;
			padding: .1rem .65rem;
			font-size: .8rem;
			font-weight: 600;
		}
		.section-past .section-title {
			color: #8a97a8;
		}

		/* --- Cartes --- */
		.conference-card {
			border: 1px solid rgba(0, 0, 0, .05);
			border-radius: 14px;
			overflow: hidden;
			transition: transform .25s ease, box-shadow .25s ease;
			background: #fff;
		}
		.conference-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 14px 34px rgba(20, 35, 60, .14) !important;
		}
		.conference-card .thumb {
			position: relative;
			aspect-ratio: 16 / 9;
			overflow: hidden;
		}
		.conference-card .thumb img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			transition: transform .35s ease;
		}
		.conference-card:hover .thumb img {
			transform: scale(1.04);
		}
		.conference-card .placeholder-img {
			width: 100%;
			height: 100%;
			background: linear-gradient(135deg, #2c3e50, #3498db);
			display: flex;
			align-items: center;
			justify-content: center;
		}

		/* Pastille date jour/mois */
		.date-chip {
			position: absolute;
			top: 12px;
			left: 12px;
			background: #fff;
			border-radius: 10px;
			padding: .35rem .6rem;
			text-align: center;
			line-height: 1.05;
			box-shadow: 0 4px 14px rgba(0, 0, 0, .18);
			min-width: 3rem;
		}
		.date-chip .day {
			display: block;
			font-size: 1.15rem;
			font-weight: 800;
			color: #2c3e50;
		}
		.date-chip .month {
			display: block;
			font-size: .68rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: .06em;
			color: #e74c3c;
		}

		.status-pill {
			position: absolute;
			top: 12px;
			right: 12px;
			padding: .25rem .7rem;
			border-radius: 50rem;
			font-size: .72rem;
			font-weight: 700;
			color: #fff;
			background: rgba(0, 0, 0, .55);
			backdrop-filter: blur(4px);
		}
		.status-pill.upcoming {
			background: rgba(24, 188, 156, .92);
		}

		.conference-card .card-body {
			padding: 1.15rem 1.25rem .75rem;
		}
		.conf-title {
			font-size: 1.05rem;
			font-weight: 700;
			color: #29323d;
			margin-bottom: .65rem;
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
			min-height: 2.6em;
			line-height: 1.3;
		}
		.conf-meta {
			margin-bottom: .7rem;
			font-size: .84rem;
			color: #6c7686;
		}
		.conf-meta li {
			display: flex;
			align-items: baseline;
			gap: .55rem;
			padding: .12rem 0;
		}
		.conf-meta i {
			width: 1rem;
			text-align: center;
			color: #9aa7b8;
		}
		.conf-desc {
			font-size: .86rem;
			color: #8a97a8;
			line-height: 1.6;
			display: -webkit-box;
			-webkit-line-clamp: 3;
			-webkit-box-orient: vertical;
			overflow: hidden;
			margin-bottom: 0;
		}
		.conference-card .card-footer {
			background: transparent;
			border-top: 1px solid rgba(0, 0, 0, .06);
			padding: .75rem 1.25rem;
		}

		/* Conférences passées : atténuées */
		.is-past .thumb img,
		.is-past .placeholder-img {
			filter: grayscale(.55) brightness(.92);
		}
		.is-past .conf-title {
			color: #5a6473;
		}

		.empty-state-public {
			text-align: center;
			padding: 4rem 1rem;
			color: #adb5bd;
		}
	</style>
{% endblock %}

{# Carte de conférence réutilisée par les deux sections #}
{% macro conf_card(conference, is_past) %}
	{% set months = ['Jan', 'Fév', 'Mars', 'Avr', 'Mai', 'Juin', 'Juil', 'Août', 'Sept', 'Oct', 'Nov', 'Déc'] %}
	<div class="col-12 col-sm-6 col-lg-4 conference-item">
		<article class="card conference-card shadow-sm h-100 {{ is_past ? 'is-past' : '' }}">
			<div class="thumb">
				{% if conference.imageName %}
					<img src="/images/conferences/{{ conference.imageName }}" alt="{{ conference.titre }}" loading="lazy">
				{% else %}
					<div class="placeholder-img">
						<i class="fas fa-microphone-alt fa-3x text-white opacity-50"></i>
					</div>
				{% endif %}
				<div class="date-chip">
					<span class="day">{{ conference.date|date('d') }}</span>
					<span class="month">{{ months[conference.date|date('n') - 1] }}</span>
				</div>
				{% if is_past %}
					<span class="status-pill">Terminée</span>
				{% else %}
					<span class="status-pill upcoming">À venir</span>
				{% endif %}
			</div>

			<div class="card-body">
				<h3 class="conf-title">{{ conference.titre }}</h3>
				<ul class="conf-meta list-unstyled">
					<li>
						<i class="fas fa-map-marker-alt"></i>
						<span>{{ conference.lieu }}</span>
					</li>
					<li>
						<i class="fas fa-clock"></i>
						<span>{{ conference.date|date('H\\hi') }}</span>
					</li>
					<li>
						<i class="fas fa-user"></i>
						<span>{{ conference.owner.prenom }} {{ conference.owner.nom }}</span>
					</li>
				</ul>
				<p class="conf-desc">{{ conference.description }}</p>
			</div>

			<div class="card-footer d-flex justify-content-between align-items-center">
				<span class="small text-muted">
					<i class="fas fa-comments me-1"></i>
					{{ conference.comments|length }}
					commentaire{{ conference.comments|length > 1 ? 's' : '' }}
				</span>
				<a href="{{ path('app_conference_show', {id: conference.id}) }}" class="btn btn-primary btn-sm rounded-pill px-3">
					Voir détails
					<i class="fas fa-arrow-right ms-1"></i>
				</a>
			</div>
		</article>
	</div>
{% endmacro %}

{% block body %}
	{% set now = date() %}
	{% set upcoming = conferences|filter(c => c.date >= now)|sort((a, b) => a.date <=> b.date) %}
	{% set past = conferences|filter(c => c.date < now)|sort((a, b) => b.date <=> a.date) %}

	{# Hero #}
	<div class="hero-section">
		<div class="container text-center">
			<h1 class="display-5 fw-bold mb-2">
				<i class="fas fa-microphone-alt me-3"></i>Conférences
			</h1>
			<p class="lead mb-0">
				{{ upcoming|length > 0
					? upcoming|length ~ ' conférence' ~ (upcoming|length > 1 ? 's' : '') ~ ' à venir — réservez vos dates !'
					: 'Découvrez et participez aux prochaines conférences' }}
			</p>
			<div class="search-bar">
				<i class="fas fa-search"></i>
				<input type="text" id="search-input" class="form-control form-control-lg rounded-pill" placeholder="Rechercher un titre, un lieu, un conférencier…">
			</div>
		</div>
	</div>

	<div class="container page-content">

		{% if conferences|length == 0 %}
			<div class="empty-state-public">
				<i class="fas fa-microphone-alt fa-4x mb-3 d-block"></i>
				<h5 class="text-muted">Aucune conférence pour le moment</h5>
				<p class="text-muted small mb-0">Revenez bientôt !</p>
			</div>
		{% endif %}

		{# --- À venir --- #}
		{% if upcoming|length > 0 %}
			<section class="mb-5" data-section>
				<h2 class="section-title">
					<i class="fas fa-calendar-check text-success"></i>
					À venir
					<span class="count-pill" data-count>{{ upcoming|length }}</span>
				</h2>
				<div class="row g-4">
					{% for conference in upcoming %}
						{{ ui.conf_card(conference, false) }}
					{% endfor %}
				</div>
			</section>
		{% endif %}

		{# --- Passées --- #}
		{% if past|length > 0 %}
			<section class="mb-5 section-past" data-section>
				<h2 class="section-title">
					<i class="fas fa-history"></i>
					Déjà passées
					<span class="count-pill" data-count>{{ past|length }}</span>
				</h2>
				<div class="row g-4">
					{% for conference in past %}
						{{ ui.conf_card(conference, true) }}
					{% endfor %}
				</div>
			</section>
		{% endif %}

		<p class="text-center text-muted d-none" id="no-results">
			<i class="fas fa-search me-1"></i>Aucune conférence ne correspond à votre recherche.
		</p>
	</div>
{% endblock %}

{% block javascripts %}
	<script>
		// Recherche en temps réel sur les deux sections
		document.getElementById('search-input').addEventListener('input', function () {
			const query = this.value.toLowerCase().trim();
			let totalVisible = 0;

			document.querySelectorAll('[data-section]').forEach(section => {
				let visible = 0;
				section.querySelectorAll('.conference-item').forEach(item => {
					const match = item.innerText.toLowerCase().includes(query);
					item.style.display = match ? '' : 'none';
					if (match) visible++;
				});
				section.querySelector('[data-count]').textContent = visible;
				section.style.display = visible > 0 ? '' : 'none';
				totalVisible += visible;
			});

			document.getElementById('no-results').classList.toggle('d-none', totalVisible > 0);
		});
	</script>
{% endblock %}
